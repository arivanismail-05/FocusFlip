<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Required permissions -->
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusFlip">
        <activity
            android:name=".controller.HistoryActivity"
            android:exported="false" />
        <activity
            android:name=".controller.TimerActivity"
            android:exported="false" />
        <activity
            android:name=".controller.SelectSubjectActivity"
            android:exported="false" />
        <activity
            android:name=".controller.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".controller.SignUpActivity"
            android:exported="false" />
        <activity
            android:name=".controller.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".controller.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".controller.MainActivity"
            android:exported="false" />
    </application>

</manifest>